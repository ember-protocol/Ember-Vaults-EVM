{
  "name": "ember-vaults-evm-smart-contracts",
  "version": "1.0.0",
  "description": "Ember Protocol EVM Smart Contracts",
  "main": "index.js",
  "scripts": {
    "test": "hardhat test",
    "coverage": "hardhat coverage",
    "compile": "hardhat compile",
    "clean-compile": "hardhat clean && hardhat compile",
    "size": "ts-node scripts/contract-sizes.ts",
    "verify": "hardhat verify",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{sol,ts,js,json}\"",
    "format:check": "prettier --check \"**/*.{sol,ts,js,json}\"",
    "format:solidity": "prettier --write \"contracts/**/*.sol\"",
    "audit:setup": "bash scripts/setup-audit-tools.sh",
    "audit:slither": "bash scripts/run-slither.sh",
    "fuzz:setup": "bash scripts/setup-fuzzing.sh",
    "fuzz": "forge test --match-contract Fuzz -vv",
    "fuzz:fast": "forge test --match-contract Fuzz --fuzz-runs 1000 -vv",
    "fuzz:deep": "forge test --match-contract Fuzz --fuzz-runs 100000 -vv",
    "fuzz:ci": "forge test --match-contract Fuzz --fuzz-runs 50000 -vv",
    "fuzz:coverage": "forge coverage --match-contract Fuzz",
    "fuzz:echidna": "echidna-test . --contract EmberVaultProperties --config echidna.yaml",
    "fuzz:echidna:docker": "docker run -it --rm -v $PWD:/src trailofbits/eth-security-toolbox echidna-test /src --contract EmberVaultProperties --config /src/echidna.yaml",
    "deploy:protocol-config": "hardhat run scripts/deploy/protocol-config.ts",
    "deploy:vault-validator": "hardhat run scripts/deploy/vault-validator.ts",
    "deploy:deposit-token": "hardhat run scripts/deploy/deposit-token.ts",
    "deploy:vault": "hardhat run scripts/deploy/ember-vault.ts",
    "deploy:eth-vault": "hardhat run scripts/deploy/ember-eth-vault.ts",
    "upgrade:vaults": "hardhat run scripts/upgrade/vault.ts",
    "upgrade:protocol-config": "hardhat run scripts/upgrade/protocol-config.ts",
    "upgrade:vault-validator": "hardhat run scripts/upgrade/vault-validator.ts",
    "upgrade:vault-implement-address": "hardhat run scripts/upgrade/vault-implement-address.ts",
    "ci:validate-upgrades": "hardhat run scripts/ci/validate-upgrades.ts",
    "ops:force-import": "hardhat run scripts/ops/force-import.ts",
    "admin:update-admin": "hardhat run scripts/update-vault-admin.ts",
    "admin:update-operator": "hardhat run scripts/update-vault-operator.ts",
    "admin:update-validator": "hardhat run scripts/update-vault-validator.ts",
    "admin:update-bridge-adapter": "hardhat run scripts/update-vault-bridge-adapter.ts",
    "interact:mint-tokens": "hardhat run scripts/interact/mint-tokens.ts",
    "interact:deposit-to-vault": "hardhat run scripts/interact/deposit-to-vault.ts",
    "interact:deposit-with-permit": "hardhat run scripts/interact/deposit-with-permit.ts",
    "interact:check-receipt-token": "hardhat run scripts/interact/check-receipt-token.ts",
    "deploy:oft-adapter": "hardhat run scripts/deploy/oft-adapter.ts",
    "bridge:set-peer": "hardhat run scripts/bridge/set-peer.ts",
    "bridge:set-adapter": "hardhat run scripts/bridge/set-vault-bridge-adapter.ts",
    "bridge:send": "hardhat run scripts/bridge/send-tokens.ts",
    "bridge:quote": "hardhat run scripts/bridge/quote-send.ts",
    "interact:deposit-eth": "hardhat run scripts/interact/deposit-eth-to-eth-vault.ts",
    "interact:deposit-weth": "hardhat run scripts/interact/deposit-weth-to-eth-vault.ts",
    "interact:mint-weth": "hardhat run scripts/interact/mint-weth.ts",
    "interact:redeem-eth-vault": "hardhat run scripts/interact/redeem-from-eth-vault.ts",
    "bridge:diagnose": "hardhat run scripts/bridge/diagnose-bridge.ts",
    "bridge:verify-peers": "hardhat run scripts/bridge/verify-peers.ts",
    "bridge:lz-scan": "npx ts-node scripts/bridge/query-lz-scan.ts",
    "bridge:set-enforced-options": "hardhat run scripts/bridge/set-enforced-options.ts",
    "bridge:set-dvn-config": "hardhat run scripts/bridge/set-dvn-config.ts",
    "bridge:pin-libraries": "hardhat run scripts/bridge/pin-libraries.ts",
    "bridge:set-delegate": "hardhat run scripts/bridge/set-delegate.ts",
    "bridge:set-adapter-paused": "hardhat run scripts/bridge/set-adapter-paused.ts",
    "lz:wire": "npx @layerzerolabs/toolbox-hardhat oapp:wire --oapp-config ./layerzero.config.ts",
    "lz:config:get": "npx @layerzerolabs/toolbox-hardhat oapp:config:get --oapp-config ./layerzero.config.ts",
    "test:mainnet-upgrade": "hardhat run scripts/test/test-mainnet-upgrade.ts",
    "interact:process-withdrawals": "hardhat run scripts/interact/process-vault-withdrawals.ts",
    "interact:process-eth-withdrawals": "hardhat run scripts/interact/process-eth-vault-withdrawals.ts",
    "interact:set-vault-validator": "hardhat run scripts/interact/set-vault-validator.ts",
    "interact:set-vault-permanent-fee": "hardhat run scripts/interact/set-vault-permanent-fee.ts",
    "interact:set-vault-time-based-fee": "hardhat run scripts/interact/set-vault-time-based-fee-percentage.ts",
    "interact:set-vault-time-based-threshold": "hardhat run scripts/interact/set-vault-time-based-fee-threshold.ts",
    "interact:set-vault-deposit-allow-list": "hardhat run scripts/interact/set-vault-deposit-allow-list.ts",
    "interact:set-vault-deposit-allow-list-batch": "hardhat run scripts/interact/set-vault-deposit-allow-list-batch.ts",
    "interact:set-vault-fee-exemption-list": "hardhat run scripts/interact/set-vault-fee-exemption-list.ts"
  },
  "keywords": [
    "ethereum",
    "smart-contracts",
    "upgradeable",
    "uups",
    "hardhat",
    "typescript",
    "ethers",
    "ember",
    "vaults",
    "layerzero",
    "oft",
    "bridge",
    "sui"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@layerzerolabs/devtools": "2.0.5",
    "@layerzerolabs/devtools-evm": "3.0.2",
    "@layerzerolabs/devtools-evm-hardhat": "4.0.4",
    "@layerzerolabs/lz-definitions": "3.0.168",
    "@layerzerolabs/oapp-alt-evm": "0.0.5",
    "@layerzerolabs/toolbox-hardhat": "0.6.13",
    "@layerzerolabs/ua-devtools": "5.0.2",
    "@layerzerolabs/ua-devtools-evm": "7.0.1",
    "@layerzerolabs/ua-devtools-evm-hardhat": "9.0.2",
    "@nomicfoundation/hardhat-chai-matchers": "2.1.0",
    "@nomicfoundation/hardhat-ethers": "3.1.2",
    "@nomicfoundation/hardhat-network-helpers": "1.1.2",
    "@nomicfoundation/hardhat-toolbox": "4.0.0",
    "@nomicfoundation/hardhat-verify": "2.1.3",
    "@openzeppelin/hardhat-upgrades": "3.9.1",
    "@typechain/ethers-v6": "0.5.1",
    "@typechain/hardhat": "9.1.0",
    "@types/chai": "4.3.20",
    "@types/mocha": "10.0.10",
    "@types/node": "20.19.25",
    "chai": "4.5.0",
    "ethers": "6.15.0",
    "hardhat": "2.27.0",
    "hardhat-gas-reporter": "1.0.10",
    "prettier": "3.6.2",
    "prettier-plugin-solidity": "2.2.0",
    "solidity-coverage": "0.8.16",
    "ts-node": "10.9.2",
    "typechain": "8.3.2",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "@layerzerolabs/lz-evm-messagelib-v2": "3.0.168",
    "@layerzerolabs/lz-evm-protocol-v2": "3.0.168",
    "@layerzerolabs/lz-evm-v1-0.7": "3.0.168",
    "@layerzerolabs/oapp-evm": "0.4.1",
    "@layerzerolabs/oft-evm": "4.0.1",
    "@openzeppelin/contracts": "5.4.0",
    "@openzeppelin/contracts-upgradeable": "5.4.0",
    "dotenv": "16.6.1",
    "solidity-bytes-utils": "0.8.4"
  },
  "packageManager": "yarn@4.14.1"
}
